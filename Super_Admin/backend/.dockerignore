# Keep the build context lean. Anything matched here is NOT shipped
# into the Docker image, so secrets / large local artifacts can't
# leak into a deployed container.

# Local Python environments
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo

# Local-only state
.env
.env.*
!.env.example

# Big runtime artifacts (Railway has no on-prem cameras / GPU; these
# would only bloat the image)
storage/
logs/

# Editor / OS junk
.idea/
.vscode/
.DS_Store
Thumbs.db

# Tests / docs not needed at runtime
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.md
